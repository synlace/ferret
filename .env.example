# ── Authentication ────────────────────────────────────────────────────────────
# Ferret requires a password set during the first-run setup wizard.
# The browser UI uses an HttpOnly session cookie (set automatically on login).
#
# For programmatic / CI access, set FERRET_API_KEY to any random secret and
# pass it as:  Authorization: Bearer <your-key>
# Leave unset to disable Bearer-token auth (browser session cookie only).
# FERRET_API_KEY=change-me-to-a-random-secret

# ── AI provider ───────────────────────────────────────────────────────────────
# AI provider and API key are configured through the in-browser setup wizard
# on first launch (http://localhost:3000).  No changes needed here to get started.
#
# OPENROUTER_MODEL overrides the default model when using OpenRouter.
# Any model available on openrouter.ai works.
OPENROUTER_MODEL=google/gemini-3-flash-preview

# ── Proxy settings ────────────────────────────────────────────────────────────
PROXY_HOST=127.0.0.1
PROXY_PORT=1337

# ── AI-generated test files ───────────────────────────────────────────────────
# Directory where the AI chat writes pytest files.
# Defaults to /data/tests (inside the named volume — always writable).
# To access tests on the host:
#   docker compose cp api:/data/tests ./tests
# Or override to a bind-mount path if you've pre-created it with correct permissions:
#   FERRET_TESTS_DIR=/tests
FERRET_TESTS_DIR=/data/tests

# ── UI ────────────────────────────────────────────────────────────────────────
# Host port the UI is exposed on (container always listens on 3000 internally).
# Change this if port 3000 is already in use on your machine.
# The API CORS allowlist is automatically updated to match this value.
UI_PORT=3000

# URL the browser-side Next.js code uses to reach the API.
# When running via docker compose this should stay as localhost:8000 because
# the UI container serves the page to the *host* browser, not to itself.
NEXT_PUBLIC_API_URL=http://localhost:8000

# SIGINT news feed URL (served by ferret-news container)
NEXT_PUBLIC_SIGINT_URL=https://synlace.ai/ferret/news.json

# ── Lab image ─────────────────────────────────────────────────────────────────
# The ferret-lab sandbox image is pre-built and published to GHCR so users only
# need to pull it (~2 min) rather than build it locally (~10–15 min).
#
# To use a locally built image instead (e.g. when modifying src/apps/lab/):
#   1. Run: just build-lab          (builds ferret-lab:local)
#   2. Set: FERRET_LAB_IMAGE=ferret-lab:local
#   3. Run: just up
#
# Leave unset to use the pre-built GHCR image (default for most users).
# FERRET_LAB_IMAGE=ferret-lab:local
